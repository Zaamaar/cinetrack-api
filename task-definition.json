{
  "family": "cinetrack-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::483528440029:role/cinetrackTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "cinetrack-api",
      "image": "483528440029.dkr.ecr.us-east-1.amazonaws.com/cinetrack-api:latest",
      "portMappings": [
        { "containerPort": 3000, "protocol": "tcp" }
      ],
      "essential": true,
      "environment": [
        { "name": "PORT", "value": "3000" },
        { "name": "DB_HOST", "value": "cinetrack-db.co3ak6osqv2m.us-east-1.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_USER", "value": "cinetrack_user" },
        { "name": "DB_NAME", "value": "cinetrack_db" },
        { "name": "DB_SSL", "value": "true" }
      ],
      "secrets": [
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:ssm:us-east-1:483528440029:parameter/cinetrack/db_password" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:ssm:us-east-1:483528440029:parameter/cinetrack/jwt_secret" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cinetrack-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
